// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PowerDataSource {
  MANUAL
  AUTO
}

enum UserRole {
  ADMIN // Toàn quyền: xem/sửa/xóa mọi thứ, quản lý user
  MANAGER // Trưởng phòng điện: quản lý danh mục (nhà máy/trạm/đồng hồ/nhóm/loại điện) + giá điện, không quản lý user
  EDITOR // Xem mọi thứ + nhập/sửa chỉ số hàng ngày, không sửa danh mục/giá điện, không xóa
  VIEWER // Chỉ xem
}

model User {
  id            String             @id @default(cuid())
  username      String             @unique
  password      String // bcrypt hash
  fullName      String
  role          UserRole           @default(VIEWER)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  factoryScopes UserFactoryScope[]

  @@index([isActive])
}

model Factory {
  id           String             @id @default(cuid())
  code         String             @unique
  name         String
  description  String?
  location     String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  transformers PowerTransformer[]
  meters        PowerMeter[]
  userScopes    UserFactoryScope[]

  @@index([isActive])
}

model UserFactoryScope {
  userId    String
  factoryId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  factory   Factory  @relation(fields: [factoryId], references: [id], onDelete: Cascade)

  @@id([userId, factoryId])
  @@index([factoryId])
}

model PowerTransformer {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  factoryId   String?
  location    String?
  capacityKva Float?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  factory     Factory?     @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  meters      PowerMeter[]
  units       PowerTransformerUnit[]

  @@index([factoryId])
  @@index([isActive])
}

model PowerTransformerUnit {
  id                Int               @id @default(autoincrement())
  code              String            @unique
  name              String
  transformerId     String?
  manufacturer      String?
  manufacturingYear Int?
  serialNumber      String?
  ratedCapacity     Float?
  ratedCapacityUnit String?           @default("kVA")
  voltageLevel      String?
  ratedCurrent      String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  transformer       PowerTransformer? @relation(fields: [transformerId], references: [id], onDelete: SetNull)
  meters            PowerMeter[]

  @@index([transformerId])
  @@index([isActive])
}

model PowerMeterGroup {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  meters      PowerMeter[]

  @@index([isActive])
}

model PowerMeter {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  meterNo       String?
  factoryId         String?
  transformerId     String?
  transformerUnitId Int?
  groupId           String?
  isActive      Boolean           @default(true)
  type          Int               @default(1) // 1: Hạ thế (1 chỉ số), 2: Trung thế (3 chỉ số Bình thường/Cao điểm/Thấp điểm)
  isAuto        Boolean           @default(false)
  modbusId      Int?
  gatewayIp     String?
  gatewayPort   Int               @default(502)
  registerAddr  Int               @default(0)
  tu            Float             @default(1)
  ti            Float             @default(1)
  // true = dong ho phuc vu muc dich NGOAI SAN XUAT (van phong, bom chua chay...).
  // Van nam trong cong to EVN cua nha may nen VAN tham gia phan bo nguoc (giu trong mau so rate),
  // chi khac o cho bao cao gom chi phi thanh 2 nhom: San xuat / Ngoai san xuat.
  isNonProduction Boolean         @default(false)
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  factory       Factory?              @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  group         PowerMeterGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  transformer     PowerTransformer?     @relation(fields: [transformerId], references: [id], onDelete: SetNull)
  transformerUnit PowerTransformerUnit? @relation(fields: [transformerUnitId], references: [id], onDelete: SetNull)
  records       PowerRecord[]
  telemetry     PowerTelemetry[]
  liveReading   PowerLiveReading?

  @@index([factoryId])
  @@index([groupId])
  @@index([transformerId])
  @@index([transformerUnitId])
  @@index([isActive, isAuto])
}

// Ban doc MOI NHAT cua moi dong ho AUTO, do collector push len (co che PUSH qua HTTPS).
// Trang realtime chi doc bang nay (khong cham Modbus qua mang) -> nhanh, on dinh.
// Khoa theo meterId (moi dong ho 1 dong duy nhat, luon upsert de duoc de len).
model PowerLiveReading {
  meterId     String     @id
  totalEnergy Float
  readAt      DateTime   @db.Timestamptz
  updatedAt   DateTime   @updatedAt
  meter       PowerMeter @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@index([readAt])
}

model ElectricityPrice {
  id            String   @id @default(cuid())
  type          String   @unique @default("NORMAL") // NORMAL, PEAK, OFF_PEAK
  name          String   @default("") // Bình thường, Cao điểm, Thấp điểm
  price         Float    @default(0)
  description   String? // Ghi chú khung giờ
  effectiveFrom DateTime @default(now())
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Phien ban bieu khung gio EVN (VD: CURRENT_2014 dang dung, NEW_2026 da khai bao san nhung chua kich hoat).
// Chi 1 version isActive=true tai 1 thoi diem - dung de tach tieu thu Ha the AUTO theo Binh thuong/Cao diem/Thap diem.
model TariffScheduleVersion {
  id            String            @id @default(cuid())
  code          String            @unique // CURRENT_2014, NEW_2026, ...
  name          String
  isActive      Boolean           @default(false)
  effectiveFrom DateTime?
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  ranges        TariffTimeRange[]

  @@index([isActive])
}

// 1 khoang gio trong ngay thuoc 1 loai gia (NORMAL/PEAK/OFF_PEAK), khong wrap qua nua dem
// (khoang 22:00-04:00 sang duoc khai bao thanh 2 dong: 22:00-24:00 va 00:00-04:00).
model TariffTimeRange {
  id          String                @id @default(cuid())
  versionId   String
  dayType     String // WEEKDAY (Thu 2 - Thu 7), SUNDAY
  priceType   String // NORMAL, PEAK, OFF_PEAK
  startMinute Int // tinh tu 00:00, 0-1439
  endMinute   Int // 1-1440, luon > startMinute
  version     TariffScheduleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([versionId, dayType])
}

model EnergyTypeCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String   @unique
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PowerTelemetry {
  id          String     @id @default(cuid())
  meterId     String
  totalEnergy Float
  voltage     Float?
  current     Float?
  power       Float?
  powerFactor Float?
  frequency   Float?
  rawData     Json?
  timestamp   DateTime   @default(now()) @db.Timestamptz
  meter       PowerMeter @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@index([meterId, timestamp])
  @@index([timestamp])
}

model PowerRecord {
  id         String          @id @default(cuid())
  recordDate DateTime
  meterId    String
  dataSource PowerDataSource @default(MANUAL)
  prevTotal  Float           @default(0)
  currTotal  Float           @default(0)
  consTotal  Float           @default(0)

  // --- Dành cho đồng hồ Trung thế (type = 2) - 3 chỉ số ---
  prevNormal  Float?
  currNormal  Float?
  consNormal  Float?
  prevPeak    Float?
  currPeak    Float?
  consPeak    Float?
  prevOffPeak Float?
  currOffPeak Float?
  consOffPeak Float?

  unitPrice  Float           @default(0)
  costTotal  Float           @default(0)
  isReset    Boolean         @default(false)
  note       String?
  createdBy  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  meter      PowerMeter      @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@unique([recordDate, meterId])
  @@index([recordDate])
  @@index([meterId])
  @@index([dataSource])
}